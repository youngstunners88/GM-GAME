; Engine Configuration File
; Godot version: 4.3

config_version=5

[application]
config/name="Lil Blunt: The Smoke Realm"
config/description="2D platformer starring Lil Blunt. Promo game for SmokeRing, DIAMONDS, and GoldMine crypto protocols."
run/main_scene="res://src/ui/main_menu.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
boot_splash/bg_color=Color(0.101961, 0.301961, 0.2, 1)

[autoload]
GoldMineSystem="*res://src/autoload/goldmine_system.gd"
GameManager="*res://src/autoload/game_manager.gd"
SceneTransition="*res://src/autoload/scene_transition.tscn"
AudioManager="*res://src/autoload/audio_manager.gd"
ScreenShake="*res://src/autoload/screen_shake.gd"
StateMachine="*res://src/autoload/state_machine.gd"
SceneRouter="*res://src/autoload/scene_router.gd"
EntitySpawner="*res://src/autoload/entity_spawner.gd"
DevCoordinator="*res://src/autoload/dev_coordinator.gd"
MobileInputHandler="*res://src/autoload/mobile_input_handler.gd"
ComboSystem="*res://src/autoload/combo_system.gd"
Web3Manager="*res://src/autoload/web3_manager.gd"

[display]
window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=true
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=6

