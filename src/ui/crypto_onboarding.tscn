[node name="Shade" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0, 0, 0, 0.72)

[node name="Panel" type="Panel" parent="."]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -380.0
offset_top = -300.0
offset_right = 380.0
offset_bottom = 300.0

[node name="VBox" type="VBoxContainer" parent="Panel"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 28.0
offset_top = 22.0
offset_right = -28.0
offset_bottom = -22.0
theme_override_constants/separation = 10

[node name="Title" type="Label" parent="Panel/VBox"]
text = "NEW TO CRYPTO? TOTALLY FINE."
theme_override_font_sizes/font_size = 26

[node name="S1" type="Label" parent="Panel/VBox"]
text = "WHAT IS SMOKERING?
A community crypto project with three linked tokens - SMOKE, DIAMONDS, and GOLD - and this game is its playground. You never need to buy anything to play."
autowrap_mode = 2
theme_override_font_sizes/font_size = 14

[node name="S2" type="Label" parent="Panel/VBox"]
text = "WHY CONNECT A WALLET?
To unlock secret levels and verified leaderboard scores. No wallet = still playable, just fewer perks."
autowrap_mode = 2
theme_override_font_sizes/font_size = 14

[node name="S3" type="Label" parent="Panel/VBox"]
text = "HOW DO I GET A WALLET?
1. Tap GET METAMASK below and install it (phone or browser).
2. Follow MetaMask's setup - it shows a recovery phrase. Write it on PAPER. Never share it, not even with us.
3. Come back and press CONNECT WALLET at the menu. Done."
autowrap_mode = 2
theme_override_font_sizes/font_size = 14

[node name="S4" type="Label" parent="Panel/VBox"]
text = "IS IT SAFE?
We check what tokens you hold to unlock in-game perks. We NEVER ask for your private key. We NEVER request permission to spend your tokens. Your wallet address is public blockchain data - we only read it, we don't store it."
autowrap_mode = 2
theme_override_font_sizes/font_size = 14
modulate = Color(0.75, 1, 0.82, 1)

[node name="Row" type="HBoxContainer" parent="Panel/VBox"]
alignment = 1
theme_override_constants/separation = 14

[node name="MetaMaskBtn" type="Button" parent="Panel/VBox/Row"]
text = "GET METAMASK"
custom_minimum_size = Vector2(180, 44)

[node name="LearnBtn" type="Button" parent="Panel/VBox/Row"]
text = "LEARN MORE"
custom_minimum_size = Vector2(150, 44)

[node name="CloseBtn" type="Button" parent="Panel/VBox/Row"]
text = "BACK TO GAME"
custom_minimum_size = Vector2(170, 44)
